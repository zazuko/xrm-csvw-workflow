@base <http://example.org/pipeline/>.
@prefix p: <https://pipeline.described.at/>.
@prefix code: <https://code.described.at/>.
@prefix op: <https://barnard59.zazuko.com/operations/>.

#
# Default variables
#

<defaultVars>
  p:variable [ a p:Variable;
    p:name "ENDPOINT_URL";
    p:value "http://localhost:3030/data"
  ], [ a p:Variable;
    p:name "ENDPOINT_USER";
    p:value ""
  ], [ a p:Variable;
    p:name "ENDPOINT_PASSWORD";
    p:value ""
  ], [ a p:Variable;
    p:name "outputFile";
    p:value "output/transformed.nt"
  ], [ a p:Variable;
    p:name "mappingFilePattern";
    p:value "src-gen/*.csv.meta.json"
  ], [ a p:Variable;
    p:name "destinationGraph";
    p:value "https://example.org/graph/users"
  ].

#
# Pipelines
#

<toFile> a p:Pipeline;
  p:variables <defaultVars>;
  p:steps [
    p:stepList (
      [ op:base\/glob [code:name "pattern"; code:value "mappingFilePattern"^^p:VariableName] ]
      [ op:base\/forEach (<readMappingCsvTriples> "csvMapping") ]
      [ op:formats\/ntriples\/serialize () ]
      [ op:core\/fs\/createWriteStream ("outputFile"^^p:VariableName) ]
    )
  ].

<toStore> a p:Pipeline;
  p:variables <defaultVars>;
  p:steps [
    p:stepList (
      [ op:base\/glob [code:name "pattern"; code:value "mappingFilePattern"^^p:VariableName] ]
      [ op:base\/forEach (<readMappingCsvTriples> "csvMapping") ]
      [ op:rdf\/setGraph ("destinationGraph"^^p:VariableName) ]
      [ op:graph-store\/put
          [code:name "endpoint"; code:value "ENDPOINT_URL"^^p:VariableName],
          [code:name "graph";    code:value "destinationGraph"^^p:VariableName],
          [code:name "user";     code:value "ENDPOINT_USER"^^p:VariableName],
          [code:name "password"; code:value "ENDPOINT_PASSWORD"^^p:VariableName]
      ]
    )
  ].

<fileToStore> a p:Pipeline;
  p:variables <defaultVars>;
  p:steps [
    p:stepList (
      [ op:core\/fs\/createReadStream ("outputFile"^^p:VariableName) ]
      [ op:formats\/n3\/parse () ]
      [ op:rdf\/setGraph ("destinationGraph"^^p:VariableName) ]
      [ op:graph-store\/put
          [code:name "endpoint"; code:value "ENDPOINT_URL"^^p:VariableName],
          [code:name "graph";    code:value "destinationGraph"^^p:VariableName],
          [code:name "user";     code:value "ENDPOINT_USER"^^p:VariableName],
          [code:name "password"; code:value "ENDPOINT_PASSWORD"^^p:VariableName]
      ]
    )
  ].

#
# Sub-pipelines
#

<readMappingCsvTriples> a p:Pipeline, p:ReadableObjectMode;
  p:steps [
    p:stepList (
      [ op:csvw\/fetch [code:name "csvw"; code:value "file:${csvMapping}"^^code:EcmaScriptTemplateLiteral] ]
      [ op:formats\/csvw\/parse [code:name "metadata"; code:value <parseMetadata>] ]
      [ op:base\/filter ([ a code:EcmaScriptModule;
          code:link <node:barnard59-csvw/filter.js#excludeCsvwTriples>
        ]) ]
    )
  ].

<parseMetadata> a p:Pipeline, p:ReadableObjectMode;
  p:steps [
    p:stepList (
      [ op:core\/fs\/createReadStream ("csvMapping"^^p:VariableName) ]
      [ op:formats\/jsonld\/parse () ]
    )
  ].
